# Node.js modules
node_modules/

# Next.js build output
.next/

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# .env file (important for environment variables like MongoDB credentials, API keys)
.env

# Optional: Ignore the build output directory if you're using Docker, etc.
dist/

# OS files (macOS, Windows, etc.)
.DS_Store
Thumbs.db

# Vercel deployment directory (if using Vercel for deployment)
.vercel/

# Next.js static output
out/

# Logs from MongoDB, in case you use local MongoDB for development
mongodb_data/

# Coverage files generated by testing frameworks
coverage/

# Yarn lock files (optional, if you're not using Yarn)
yarn.lock

# Optional: Ignore temporary or user-specific files
.idea/
.vscode/

# Optional: Ignore files that might be created by other services or tools
*.swp
temp_auto_push.bat
temp_interactive_push.bat
